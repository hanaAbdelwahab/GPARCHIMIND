@startuml
autonumber
actor User
participant "Face Detection Module" as FaceDetectionModule
participant "Gesture Recognition Module" as GestureRecognitionModule
participant "Hand Tracking Module" as HandTrackingModule
participant "Interaction Module" as InteractionModule
participant "Action Customization Module" as ActionCustomizationModule
participant "Collaboration Module" as CollaborationModule
participant "Latency Reduction Module" as LatencyReductionModule
FaceDetectionModule ->> GestureRecognitionModule : Send face detection result
GestureRecognitionModule ->> HandTrackingModule : Send gesture recognition result
HandTrackingModule -> InteractionModule : Notify hand presence
InteractionModule ->> ActionCustomizationModule : Request action customization
ActionCustomizationModule ->> CollaborationModule : Send customized action
CollaborationModule ->> LatencyReductionModule : Request latency reduction
LatencyReductionModule -> InteractionModule : Notify action execution
@enduml