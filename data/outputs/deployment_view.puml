@startuml
!theme plain
left to right direction
node "Client" {
  component "User"
}
node "Kubernetes Ingress" {
  component "Ingress Controller"
}
node "CV Parser Pod" {
  component "CV Parser"
}
node "Screening Question Engine Pod" {
  component "Screening Question Engine"
}
node "Job Matching Algorithm Pod" {
  component "Job Matching Algorithm"
}
node "User Interface Pod" {
  component "User Interface"
}
node "Rating Engine Pod" {
  component "Rating Engine"
}
node "ChatGPT Integration Pod" {
  component "ChatGPT Integration"
}
"User" --> "Ingress Controller" : TCP/IP
"Ingress Controller" --> "API Gateway Pod" : HTTP/HTTPS
"User" --> "Ingress Controller"
"Ingress Controller" --> "API Gateway Pod"
"API Gateway Pod" --> "CV Parser Pod"
"API Gateway Pod" --> "Screening Question Engine Pod"
"API Gateway Pod" --> "Job Matching Algorithm Pod"
"API Gateway Pod" --> "User Interface Pod"
"API Gateway Pod" --> "Rating Engine Pod"
"API Gateway Pod" --> "ChatGPT Integration Pod"
node "Secondary Region" {
  component "Replica Services"
}
"Ingress Controller" --> "Secondary Region" : failover
@enduml