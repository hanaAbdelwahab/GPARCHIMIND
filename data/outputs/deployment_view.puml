@startuml
!theme plain
left to right direction
node "Client" {
  component "User"
}
node "Kubernetes Ingress" {
  component "Ingress Controller"
}
node "CVParser Pod" {
  component "CVParser"
}
node "CVViewer Pod" {
  component "CVViewer"
}
node "ScreeningQuestionManager Pod" {
  component "ScreeningQuestionManager"
}
node "RatingEngine Pod" {
  component "RatingEngine"
}
node "APIGateway Pod" {
  component "APIGateway"
}
node "Security Pod" {
  component "Security"
}
node "Database StatefulSet" {
  database "Database"
}
"User" --> "Ingress Controller" : TCP/IP
"Ingress Controller" --> "API Gateway Pod" : HTTP/HTTPS
"User" --> "Ingress Controller"
"Ingress Controller" --> "API Gateway Pod"
"API Gateway Pod" --> "CVParser Pod"
"API Gateway Pod" --> "CVViewer Pod"
"API Gateway Pod" --> "ScreeningQuestionManager Pod"
"API Gateway Pod" --> "RatingEngine Pod"
"API Gateway Pod" --> "APIGateway Pod"
"API Gateway Pod" --> "Security Pod"
"CVParser Pod" --> "Database StatefulSet"
"CVViewer Pod" --> "Database StatefulSet"
"ScreeningQuestionManager Pod" --> "Database StatefulSet"
"RatingEngine Pod" --> "Database StatefulSet"
"APIGateway Pod" --> "Database StatefulSet"
"Security Pod" --> "Database StatefulSet"
node "Secondary Region" {
  component "Replica Services"
}
"Ingress Controller" --> "Secondary Region" : failover
@enduml