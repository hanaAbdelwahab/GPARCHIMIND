@startuml
!theme plain
left to right direction
node "Client" {
  component "User"
}
node "Kubernetes Ingress" {
  component "Ingress Controller"
}
node "CV Parser Pod" {
  component "CV Parser"
}
node "CV Editor Pod" {
  component "CV Editor"
}
node "Screening Question Manager Pod" {
  component "Screening Question Manager"
}
node "Rating Generator Pod" {
  component "Rating Generator"
}
"User" --> "Ingress Controller" : TCP/IP
"Ingress Controller" --> "API Gateway Pod" : HTTP/HTTPS
"User" --> "Ingress Controller"
"Ingress Controller" --> "API Gateway Pod"
"API Gateway Pod" --> "CV Parser Pod"
"API Gateway Pod" --> "CV Editor Pod"
"API Gateway Pod" --> "Screening Question Manager Pod"
"API Gateway Pod" --> "Rating Generator Pod"
node "Secondary Region" {
  component "Replica Services"
}
"Ingress Controller" --> "Secondary Region" : failover
@enduml