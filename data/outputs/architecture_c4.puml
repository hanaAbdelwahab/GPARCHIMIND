@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml
LAYOUT_WITH_LEGEND()
System_Boundary(LibraryManagementSystem, "LibraryManagementSystem") {
  Container(Camera, "Camera", "Service", "Captures hand gesture commands and the user's facial features as input to the system.")
  Container(YOLOv5Model, "YOLOv5 Model", "Service", "Detects the user's face using the YOLOv5 model.")
  Container(BackgroundSubtractionBS, "Background Subtraction (BS)", "Service", "Separates the moving parts (e.g., user's hand movement) from the background.")
  Container(HistogramEqualization, "Histogram Equalization", "Service", "Optimizes image contrast.")
  Container(Threading, "Threading", "Service", "Enables concurrent execution of tasks within a single process.")
  Container(Multiprocessing, "Multiprocessing", "Service", "Enables parallel execution of tasks across multiple processes and is beneficial for data-intensive operations.")
  Container(GestureRecognition, "Gesture Recognition", "Service", "Recognizes and interprets hand gestures.")
  Container(FaceRecognition, "Face Recognition", "Service", "Recognizes and identifies the user's face.")
  Container(HandTracking, "Hand Tracking", "Service", "Tracks the user's hand movements.")
  Container(SingleHandInteraction, "Single-Hand Interaction", "Service", "Allows the user to interact with the system using a single hand.")
  Container(CustomGestureActions, "Custom Gesture Actions", "Service", "Customizes the actions for specific gestures.")
}
Rel(Camera, YOLOv5Model, "call", "Sync")
Rel(YOLOv5Model, BackgroundSubtractionBS, "call", "Sync")
Rel(BackgroundSubtractionBS, HistogramEqualization, "call", "Sync")
Rel(HistogramEqualization, GestureRecognition, "call", "Sync")
Rel(Camera, GestureRecognition, "event", "Async")
Rel(GestureRecognition, HandTracking, "call", "Sync")
Rel(HandTracking, SingleHandInteraction, "call", "Sync")
Rel(SingleHandInteraction, CustomGestureActions, "call", "Sync")
Rel(Camera, FaceRecognition, "event", "Async")
Rel(FaceRecognition, SingleHandInteraction, "call", "Sync")
Rel(BackgroundSubtractionBS, Multiprocessing, "call", "Sync")
Rel(Multiprocessing, Threading, "call", "Sync")
Rel(Threading, CustomGestureActions, "call", "Sync")
@enduml