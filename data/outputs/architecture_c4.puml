@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml
LAYOUT_WITH_LEGEND()
System_Boundary(ResuFitPrecisionCVMatchingSystem, "ResuFit: Precision CV Matching System") {
  Container(GestureAnalysis, "Gesture Analysis", "Service", "Analyze gestures and reflect the corresponding action on the projected surface.")
  Container(GestureRecognition, "Gesture Recognition", "Service", "Include gesture recognition.")
  Container(FaceRecognition, "Face Recognition", "Service", "Include face recognition.")
  Container(HandTracking, "Hand Tracking", "Service", "Include hand tracking.")
  Container(SingleHandInteraction, "Single-Hand Interaction", "Service", "Include single-hand interaction.")
  Container(CustomizableGestures, "Customizable Gestures", "Service", "Customize the actions for specific gestures.")
  Container(RealTimeCollaboration, "Real-Time Collaboration", "Service", "Enable real-time collaboration by supporting interactions on the projected surface.")
  Container(LowLatency, "Low-Latency", "Service", "Have low-latency.")
  Container(PlaceAgnostic, "Place-Agnostic", "Service", "Work effectively in different places.")
  Container(FaceDetection, "Face Detection", "Service", "Detect the user's face using the YOLOv5 model.")
  Container(ContourDetection, "Contour Detection", "Service", "Use contours detection to detect the borders of objects.")
  Container(GaussianBlur, "Gaussian Blur", "Service", "Use Gaussian blur to mute the image noise.")
  Container(BackgroundSubtraction, "Background Subtraction", "Service", "Use Background Subtraction (BS) to separate the moving parts.")
  Container(HistogramEqualization, "Histogram Equalization", "Service", "Use Histogram Equalization for image contrast optimization.")
  Container(Threading, "Threading", "Service", "Use threading for concurrent execution of tasks within a single process.")
  Container(Multiprocessing, "Multiprocessing", "Service", "Use multiprocessing for parallel execution of tasks across multiple processes.")
}
Rel(GestureAnalysis, GestureRecognition, "call", "Sync")
Rel(GestureRecognition, FaceRecognition, "call", "Sync")
Rel(FaceRecognition, HandTracking, "call", "Sync")
Rel(HandTracking, SingleHandInteraction, "call", "Sync")
Rel(SingleHandInteraction, CustomizableGestures, "call", "Sync")
Rel(CustomizableGestures, RealTimeCollaboration, "event", "Async")
Rel(RealTimeCollaboration, LowLatency, "call", "Sync")
Rel(LowLatency, PlaceAgnostic, "call", "Sync")
Rel(FaceDetection, ContourDetection, "call", "Sync")
Rel(ContourDetection, GaussianBlur, "call", "Sync")
Rel(GaussianBlur, BackgroundSubtraction, "call", "Sync")
Rel(BackgroundSubtraction, HistogramEqualization, "call", "Sync")
Rel(HistogramEqualization, Threading, "call", "Sync")
Rel(Threading, Multiprocessing, "event", "Async")
@enduml