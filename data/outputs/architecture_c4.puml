@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml
LAYOUT_WITH_LEGEND()
System_Boundary(ResuFitPrecisionCVMatchingSystem, "ResuFit: Precision CV Matching System") {
  Container(SubmitCV, "Submit CV", "Service", "Applicants can submit their CVs for parsing and analysis.")
  Container(ViewandEditCV, "View and Edit CV", "Service", "Applicants can view and edit their parsed CV.")
  Container(AnswerScreeningQuestions, "Answer Screening Questions", "Service", "Applicants are presented with screening questions defined by an expert recruiter.")
  Container(GetRatingforCV, "Get Rating for CV", "Service", "Applicants receive a rating for their CV based on the similarity between the applicant's CV and the job requirements.")
}
Rel(SubmitCV, ViewandEditCV, "event", "Async")
Rel(ViewandEditCV, AnswerScreeningQuestions, "event", "Async")
Rel(AnswerScreeningQuestions, GetRatingforCV, "call", "Sync")
Rel(GetRatingforCV, SubmitCV, "event", "Async")
@enduml