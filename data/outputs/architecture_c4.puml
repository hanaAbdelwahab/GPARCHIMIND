@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml
LAYOUT_WITH_LEGEND()
System_Boundary(LibraryManagementSystem, "LibraryManagementSystem") {
  Container(FaceDetectionModule, "Face Detection Module", "Service", "Detect the user's face using the YOLOv5 model, contours detection, Gaussian blur, Background Subtraction (BS), and Histogram Equalization.")
  Container(GestureRecognitionModule, "Gesture Recognition Module", "Service", "Recognize gestures using threading for concurrent execution of tasks within a single process and multiprocessing for parallel execution of tasks across multiple processes.")
  Container(HandTrackingModule, "Hand Tracking Module", "Service", "Track the user's hand using Background Subtraction (BS).")
  Container(InteractionModule, "Interaction Module", "Service", "Support single-hand interaction, exclude multiple-hand interaction, and allow users to customize actions for specific gestures.")
  Container(CollaborationModule, "Collaboration Module", "Service", "Enable real-time collaboration by supporting interactions on the projected surface and foster collaborative environments for business or educational purposes.")
  Container(LatencyOptimizationModule, "Latency Optimization Module", "Service", "Analyze gestures and reflect the corresponding action on the projected surface with low-latency.")
}
Rel(FaceDetectionModule, HandTrackingModule, "event", "Async")
Rel(HandTrackingModule, GestureRecognitionModule, "event", "Async")
Rel(GestureRecognitionModule, InteractionModule, "call", "Sync")
Rel(InteractionModule, CollaborationModule, "event", "Async")
Rel(CollaborationModule, LatencyOptimizationModule, "event", "Async")
Rel(LatencyOptimizationModule, InteractionModule, "event", "Async")
Rel(FaceDetectionModule, GestureRecognitionModule, "event", "Async")
@enduml