@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml
LAYOUT_WITH_LEGEND()
System_Boundary(ResuFitPrecisionCVMatchingSystem, "ResuFit: Precision CV Matching System") {
  Container(CVParser, "CVParser", "Service", "Parses and analyzes submitted CVs")
  Container(CVViewer, "CVViewer", "Service", "Displays the parsed CV to applicants for viewing and editing")
  Container(ScreeningQuestionManager, "ScreeningQuestionManager", "Service", "Manages screening questions and presents them to applicants")
  Container(RatingEngine, "RatingEngine", "Service", "Generates a percentage-based result to evaluate each applicant's CV")
  ContainerDb(Database, "Database", "Database", "Stores and retrieves CV data, screening questions, and ratings")
  Container(APIGateway, "APIGateway", "REST API", "Handles incoming requests and routes them to the appropriate components")
  Container(Security, "Security", "Service", "Ensures secure authentication and authorization for applicants and recruiters")
}
Rel(APIGateway, CVParser, "call", "Sync")
Rel(APIGateway, ScreeningQuestionManager, "call", "Sync")
Rel(APIGateway, RatingEngine, "call", "Sync")
Rel(APIGateway, Database, "call", "Sync")
Rel(APIGateway, Security, "event", "Async")
Rel(CVParser, CVViewer, "call", "Sync")
Rel(ScreeningQuestionManager, CVViewer, "call", "Sync")
Rel(RatingEngine, Database, "call", "Sync")
Rel(Database, APIGateway, "call", "Sync")
Rel(Security, APIGateway, "event", "Async")
@enduml