@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml
LAYOUT_WITH_LEGEND()
System_Boundary(ResuFitPrecisionCVMatchingSystem, "ResuFit: Precision CV Matching System") {
  Container(CVParser, "CV Parser", "Service", "Parse and extract key information from the applicant's CV")
  Container(ScreeningQuestionValidator, "Screening Question Validator", "Service", "Verify and grade applicant responses against an expert-generated model")
  Container(CosineSimilarityCalculator, "Cosine Similarity Calculator", "Service", "Assess the alignment between CV information and job requirements using cosine similarity")
  Container(JaccardSimilarityCalculator, "Jaccard Similarity Calculator", "Service", "Assess the alignment between CV information and job requirements using Jaccard similarity")
  Container(RatingGenerator, "Rating Generator", "Service", "Generate a percentage-based result representing the applicant's overall suitability for the role")
  Container(CVComparisonModule, "CV Comparison Module", "Service", "Compare CV information with job requirements and generate a ranking")
  Container(ChatGPTValidator, "ChatGPT Validator", "Service", "Validate and score applicant responses using ChatGPT")
  Container(SubmitCVModule, "Submit CV Module", "Service", "Allow applicants to submit their CVs for parsing and analysis")
  Container(ViewandEditCVModule, "View and Edit CV Module", "Service", "Enable applicants to view and edit their parsed CV")
  Container(AnswerScreeningQuestionsModule, "Answer Screening Questions Module", "Service", "Present applicants with screening questions defined by an expert recruiter")
  Container(GetRatingforCVModule, "Get Rating for CV Module", "Service", "Provide applicants with a rating for their submitted CV")
}
Rel(SubmitCVModule, CVParser, "call", "Sync")
Rel(CVParser, CVComparisonModule, "call", "Sync")
Rel(CVComparisonModule, RatingGenerator, "call", "Sync")
Rel(CVComparisonModule, GetRatingforCVModule, "call", "Sync")
Rel(SubmitCVModule, ViewandEditCVModule, "event", "Async")
Rel(ViewandEditCVModule, SubmitCVModule, "event", "Async")
Rel(AnswerScreeningQuestionsModule, ScreeningQuestionValidator, "call", "Sync")
Rel(ScreeningQuestionValidator, RatingGenerator, "call", "Sync")
Rel(SubmitCVModule, ChatGPTValidator, "call", "Sync")
Rel(ChatGPTValidator, RatingGenerator, "call", "Sync")
Rel(SubmitCVModule, CosineSimilarityCalculator, "call", "Sync")
Rel(CosineSimilarityCalculator, CVComparisonModule, "call", "Sync")
Rel(SubmitCVModule, JaccardSimilarityCalculator, "call", "Sync")
Rel(JaccardSimilarityCalculator, CVComparisonModule, "call", "Sync")
Rel(AnswerScreeningQuestionsModule, ChatGPTValidator, "call", "Sync")
Rel(ChatGPTValidator, RatingGenerator, "call", "Sync")
@enduml