@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml
LAYOUT_WITH_LEGEND()
System_Boundary(ResuFitPrecisionCVMatchingSystem, "ResuFit: Precision CV Matching System") {
  Container(UserInterface, "User Interface", "Service", "Handle user interactions, including uploading images, recording voice, and conversing with the avatar.")
  Container(ImageProcessing, "Image Processing", "Service", "Convert uploaded images to 3D models and generate lifelike digital twin avatars.")
  Container(VoiceCloning, "Voice Cloning", "Service", "Clone the user's voice and make the avatar adapt to the user's voice.")
  Container(AvatarCustomization, "Avatar Customization", "Service", "Allow users to customize their avatar's look and express emotions based on images and conversations.")
  Container(NaturalLanguageProcessingNLP, "Natural Language Processing (NLP)", "Service", "Use the GPT-4 model for state-of-the-art natural language processing and respond to user questions.")
  Container(AuthenticationandAuthorization, "Authentication and Authorization", "Service", "Handle user sign-up, login, profile editing, and logout functionality.")
  Container(AvatarCreation, "Avatar Creation", "Service", "Create avatars based on user requirements and make them adapt to the user.")
  Container(EmotionExpression, "Emotion Expression", "Service", "Make the avatar express emotions based on images and conversations.")
  Container(SystemAdministration, "System Administration", "Service", "Create accounts for administrators and provide access to system data and features.")
}
Rel(UserInterface, ImageProcessing, "event", "Async")
Rel(ImageProcessing, AvatarCustomization, "call", "Sync")
Rel(VoiceCloning, AvatarCustomization, "call", "Sync")
Rel(AvatarCustomization, EmotionExpression, "event", "Async")
Rel(NaturalLanguageProcessingNLP, AvatarCustomization, "call", "Sync")
Rel(AvatarCreation, AvatarCustomization, "call", "Sync")
Rel(AuthenticationandAuthorization, AvatarCreation, "event", "Async")
Rel(SystemAdministration, AuthenticationandAuthorization, "event", "Async")
@enduml