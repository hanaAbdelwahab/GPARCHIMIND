@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml
LAYOUT_WITH_LEGEND()
System_Boundary(LibraryManagementSystem, "LibraryManagementSystem") {
  Container(GestureRecognitionModule, "Gesture Recognition Module", "Service", "Analyze gestures and reflect the corresponding action on the projected surface.")
  Container(FaceRecognitionModule, "Face Recognition Module", "Service", "Detect the user's face using the YOLOv5 model.")
  Container(HandTrackingModule, "Hand Tracking Module", "Service", "Track the user's hand movements.")
  Container(SingleHandInteractionModule, "Single-Hand Interaction Module", "Service", "Enable single-hand interaction with the projected surface.")
  Container(CustomizationModule, "Customization Module", "Service", "Customize the actions for specific gestures.")
  Container(RealTimeCollaborationModule, "Real-Time Collaboration Module", "Service", "Enable real-time collaboration by supporting interactions on the projected surface.")
  Container(ImageProcessingModule, "Image Processing Module", "Service", "['Detect the borders of objects using contours detection.', 'Mute the image noise using Gaussian blur.', 'Separate the moving parts from the background using Background Subtraction (BS).', 'Optimize the image contrast using Histogram Equalization.']")
  Container(BackgroundSubtractionModule, "Background Subtraction Module", "Service", "Separate the moving parts from the background using Background Subtraction (BS).")
  Container(ThreadingModule, "Threading Module", "Service", "Enable concurrent execution of tasks within a single process using threading.")
  Container(MultiprocessingModule, "Multiprocessing Module", "Service", "Enable parallel execution of tasks across multiple processes using multiprocessing.")
  Container(LatencyOptimizationModule, "Latency Optimization Module", "Service", "Ensure low-latency performance.")
  Container(EnvironmentalAdaptationModule, "Environmental Adaptation Module", "Service", "Work effectively in different places.")
}
Rel(GestureRecognitionModule, HandTrackingModule, "event", "Async")
Rel(HandTrackingModule, SingleHandInteractionModule, "call", "Sync")
Rel(FaceRecognitionModule, HandTrackingModule, "event", "Async")
Rel(HandTrackingModule, ImageProcessingModule, "call", "Sync")
Rel(ImageProcessingModule, BackgroundSubtractionModule, "call", "Sync")
Rel(BackgroundSubtractionModule, GestureRecognitionModule, "call", "Sync")
Rel(CustomizationModule, GestureRecognitionModule, "call", "Sync")
Rel(RealTimeCollaborationModule, SingleHandInteractionModule, "event", "Async")
Rel(ImageProcessingModule, RealTimeCollaborationModule, "call", "Sync")
Rel(ThreadingModule, MultiprocessingModule, "call", "Sync")
Rel(MultiprocessingModule, LatencyOptimizationModule, "call", "Sync")
Rel(LatencyOptimizationModule, RealTimeCollaborationModule, "call", "Sync")
Rel(EnvironmentalAdaptationModule, RealTimeCollaborationModule, "event", "Async")
@enduml