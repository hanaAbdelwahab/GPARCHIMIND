@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml
LAYOUT_WITH_LEGEND()
System_Boundary(ResuFitPrecisionCVMatchingSystem, "ResuFit: Precision CV Matching System") {
  Container(CVParser, "CV Parser", "Service", "Parse CV, Extract Key Information, Compare CV with Job Requirements")
  Container(ScreeningQuestionsModule, "Screening Questions Module", "Service", "Present Screening Questions, Validate Applicant Responses, Score Applicant Responses")
  Container(RatingandScoringModule, "Rating and Scoring Module", "Service", "Determine Similarity, Generate Percentage-Based Result")
  Container(UserInterfaceModule, "User Interface Module", "Service", "Submit CV, View and Edit CV, Answer Screening Questions, Get Rating for CV")
  Container(NaturalLanguageProcessingNLPModule, "Natural Language Processing (NLP) Module", "Service", "Parse CV, Determine Similarity")
  Container(SimilarityCalculationModule, "Similarity Calculation Module", "Service", "Calculate Cosine Similarity, Calculate Jaccard Similarity")
  Container(ChatGPTIntegrationModule, "ChatGPT Integration Module", "Service", "Score Applicant Responses")
  Container(RecruiterDashboardModule, "Recruiter Dashboard Module", "Service", "Define Job Requirements, View Applicant Responses, View Rating Results")
}
Rel(CVParser, ScreeningQuestionsModule, "event", "Async")
Rel(CVParser, RatingandScoringModule, "call", "Sync")
Rel(ScreeningQuestionsModule, RatingandScoringModule, "event", "Async")
Rel(RatingandScoringModule, UserInterfaceModule, "call", "Sync")
Rel(UserInterfaceModule, CVParser, "event", "Async")
Rel(UserInterfaceModule, ScreeningQuestionsModule, "event", "Async")
Rel(NaturalLanguageProcessingNLPModule, RatingandScoringModule, "call", "Sync")
Rel(SimilarityCalculationModule, RatingandScoringModule, "call", "Sync")
Rel(ChatGPTIntegrationModule, RatingandScoringModule, "call", "Sync")
Rel(UserInterfaceModule, ChatGPTIntegrationModule, "event", "Async")
Rel(UserInterfaceModule, RecruiterDashboardModule, "event", "Async")
Rel(ScreeningQuestionsModule, RecruiterDashboardModule, "event", "Async")
Rel(RatingandScoringModule, RecruiterDashboardModule, "call", "Sync")
@enduml