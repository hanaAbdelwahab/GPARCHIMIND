@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml
LAYOUT_WITH_LEGEND()
System_Boundary(ResuFitPrecisionCVMatchingSystem, "ResuFit: Precision CV Matching System") {
  Container(AuthenticationService, "Authentication Service", "Service", "Handles user authentication, including login, registration, and account deletion.")
  Container(UserProfileService, "User Profile Service", "Service", "Manages user profiles, including editing account information and deleting profiles.")
  Container(CrimeReportingService, "Crime Reporting Service", "Service", "Allows users to report crimes, including uploading pictures, editing crime details, and deleting crimes.")
  Container(DashboardService, "Dashboard Service", "Service", "Updates the dashboard with crime data and provides a visual representation of crimes on a map.")
  Container(AdminConsole, "Admin Console", "Service", "Provides administrators with tools to manage crimes, including viewing crime details, adding new crime types, and connecting police to crimes.")
  Container(ImageProcessingService, "Image Processing Service", "Service", "Validates crimes by image processing and asks users to re-upload photos if an error happens.")
  Container(RouteGenerationService, "Route Generation Service", "Service", "Generates safer routes to users based on crime data.")
  Container(ChatService, "Chat Service", "Service", "Allows users to chat with administrators for emergency contact.")
  ContainerDb(DatabaseService, "Database Service", "Database", "Stores and retrieves data for the system, including user profiles, crime reports, and dashboard data.")
}
Rel(AuthenticationService, UserProfileService, "call", "Sync")
Rel(AuthenticationService, CrimeReportingService, "event", "Async")
Rel(CrimeReportingService, ImageProcessingService, "call", "Sync")
Rel(ImageProcessingService, CrimeReportingService, "event", "Async")
Rel(CrimeReportingService, DashboardService, "call", "Sync")
Rel(DashboardService, RouteGenerationService, "call", "Sync")
Rel(RouteGenerationService, DashboardService, "event", "Async")
Rel(CrimeReportingService, AdminConsole, "event", "Async")
Rel(AdminConsole, DatabaseService, "call", "Sync")
Rel(DatabaseService, AdminConsole, "event", "Async")
Rel(ChatService, AdminConsole, "event", "Async")
Rel(AdminConsole, DatabaseService, "call", "Sync")
Rel(UserProfileService, DatabaseService, "call", "Sync")
Rel(DatabaseService, UserProfileService, "event", "Async")
@enduml