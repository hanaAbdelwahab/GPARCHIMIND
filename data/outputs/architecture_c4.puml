@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml
LAYOUT_WITH_LEGEND()
System_Boundary(ResuFitPrecisionCVMatchingSystem, "ResuFit: Precision CV Matching System") {
  Container(APIGateway, "API Gateway", "REST API", "Route client requests")
  Container(UserService, "User Service", "Service", "Manage users")
  Container(OrderService, "Order Service", "Service", "Manage orders")
  ContainerDb(OrderDatabase, "Order Database", "Database", "Persist order data")
}
Rel(APIGateway, UserService, "call", "Sync")
Rel(APIGateway, OrderService, "call", "Sync")
Rel(OrderService, OrderDatabase, "call", "Sync")
@enduml