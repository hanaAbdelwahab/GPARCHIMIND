@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml
LAYOUT_WITH_LEGEND()
System_Boundary(LibraryManagementSystem, "LibraryManagementSystem") {
  Container(FaceDetectionModule, "Face Detection Module", "Service", "Detect the user's face using the YOLOv5 model, and use contours detection, Gaussian blur, Background Subtraction (BS), and Histogram Equalization for image processing.")
  Container(HandMovementDetectionModule, "Hand Movement Detection Module", "Service", "Detect the user's hand movement using Background Subtraction (BS), and use contours detection, Gaussian blur, and Histogram Equalization for image processing.")
  Container(GestureRecognitionModule, "Gesture Recognition Module", "Service", "Recognize gestures using contours detection, Gaussian blur, Background Subtraction (BS), and Histogram Equalization for image processing.")
  Container(FaceRecognitionModule, "Face Recognition Module", "Service", "Recognize faces using contours detection, Gaussian blur, Background Subtraction (BS), and Histogram Equalization for image processing.")
  Container(HandTrackingModule, "Hand Tracking Module", "Service", "Track hands using contours detection, Gaussian blur, Background Subtraction (BS), and Histogram Equalization for image processing.")
  Container(SingleHandInteractionModule, "Single-Hand Interaction Module", "Service", "Support single-hand interaction using contours detection, Gaussian blur, Background Subtraction (BS), and Histogram Equalization for image processing.")
  Container(CustomizableGestureModule, "Customizable Gesture Module", "Service", "Allow users to customize actions for specific gestures using contours detection, Gaussian blur, Background Subtraction (BS), and Histogram Equalization for image processing.")
}
Rel(FaceDetectionModule, FaceRecognitionModule, "call", "Sync")
Rel(HandMovementDetectionModule, HandTrackingModule, "call", "Sync")
Rel(HandMovementDetectionModule, GestureRecognitionModule, "event", "Async")
Rel(GestureRecognitionModule, SingleHandInteractionModule, "event", "Async")
Rel(GestureRecognitionModule, CustomizableGestureModule, "event", "Async")
Rel(HandTrackingModule, SingleHandInteractionModule, "call", "Sync")
Rel(CustomizableGestureModule, SingleHandInteractionModule, "event", "Async")
@enduml