@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml
LAYOUT_WITH_LEGEND()
System_Boundary(system, "LibraryManagementSystem") {
  Container(UserService, "User Service", "Service", "Handle user registration and authentication")
  Container(MemberService, "Member Service", "Service", "Manage library members")
  Container(CatalogService, "Catalog Service", "Service", "Catalog books and authors")
  Container(SearchService, "Search Service", "Service", "Search and browse books")
  Container(BorrowingService, "Borrowing Service", "Service", "Borrow and return books")
  Container(HistoryService, "History Service", "Service", "Track borrowing history")
  Container(NotificationService, "Notification Service", "Service", "Send due date notifications")
}
Rel(UserService, MemberService, "event", "Async")
Rel(UserService, CatalogService, "call", "Sync")
Rel(MemberService, CatalogService, "call", "Sync")
Rel(CatalogService, SearchService, "call", "Sync")
Rel(SearchService, BorrowingService, "event", "Async")
Rel(BorrowingService, HistoryService, "call", "Sync")
Rel(BorrowingService, NotificationService, "event", "Async")
Rel(HistoryService, NotificationService, "call", "Sync")
@enduml