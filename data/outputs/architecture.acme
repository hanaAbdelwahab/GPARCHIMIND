System ResuFit:PrecisionCVMatchingSystem {
  Property view : String = "runtime";
  Property architectureStyle : String = "Layered (N-Tier)";
  Property source : String = "AI";
  Component CVParser = new Component {
    Port in;
    Port out;
    Property responsibility : String = "Parse and extract key information from the applicant's CV";
    Property state : String = "stateless";
    Property scaling : String = "horizontal";
  }
  Component ScreeningQuestionValidator = new Component {
    Port in;
    Port out;
    Property responsibility : String = "Verify and grade applicant responses against an expert-generated model";
    Property state : String = "stateless";
    Property scaling : String = "horizontal";
  }
  Component CosineSimilarityCalculator = new Component {
    Port in;
    Port out;
    Property responsibility : String = "Assess the alignment between CV information and job requirements using cosine similarity";
    Property state : String = "stateless";
    Property scaling : String = "horizontal";
  }
  Component JaccardSimilarityCalculator = new Component {
    Port in;
    Port out;
    Property responsibility : String = "Assess the alignment between CV information and job requirements using Jaccard similarity";
    Property state : String = "stateless";
    Property scaling : String = "horizontal";
  }
  Component RatingGenerator = new Component {
    Port in;
    Port out;
    Property responsibility : String = "Generate a percentage-based result representing the applicant's overall suitability for the role";
    Property state : String = "stateless";
    Property scaling : String = "horizontal";
  }
  Component CVComparisonModule = new Component {
    Port in;
    Port out;
    Property responsibility : String = "Compare CV information with job requirements and generate a ranking";
    Property state : String = "stateless";
    Property scaling : String = "horizontal";
  }
  Component ChatGPTValidator = new Component {
    Port in;
    Port out;
    Property responsibility : String = "Validate and score applicant responses using ChatGPT";
    Property state : String = "stateless";
    Property scaling : String = "horizontal";
  }
  Component SubmitCVModule = new Component {
    Port in;
    Port out;
    Property responsibility : String = "Allow applicants to submit their CVs for parsing and analysis";
    Property state : String = "stateless";
    Property scaling : String = "horizontal";
  }
  Component ViewandEditCVModule = new Component {
    Port in;
    Port out;
    Property responsibility : String = "Enable applicants to view and edit their parsed CV";
    Property state : String = "stateless";
    Property scaling : String = "horizontal";
  }
  Component AnswerScreeningQuestionsModule = new Component {
    Port in;
    Port out;
    Property responsibility : String = "Present applicants with screening questions defined by an expert recruiter";
    Property state : String = "stateless";
    Property scaling : String = "horizontal";
  }
  Component GetRatingforCVModule = new Component {
    Port in;
    Port out;
    Property responsibility : String = "Provide applicants with a rating for their submitted CV";
    Property state : String = "stateless";
    Property scaling : String = "horizontal";
  }
  Attachment SubmitCVModule.out to CVParser.in {
    Property delivery : String = "at-least-once";
    Property ordering : Boolean = true;
    Property backpressure : String = "bounded";
  }
  Attachment CVParser.out to CVComparisonModule.in {
    Property delivery : String = "at-least-once";
    Property ordering : Boolean = true;
    Property backpressure : String = "bounded";
  }
  Attachment CVComparisonModule.out to RatingGenerator.in {
    Property delivery : String = "at-least-once";
    Property ordering : Boolean = true;
    Property backpressure : String = "bounded";
  }
  Attachment CVComparisonModule.out to GetRatingforCVModule.in {
    Property delivery : String = "at-least-once";
    Property ordering : Boolean = true;
    Property backpressure : String = "bounded";
  }
  Attachment SubmitCVModule.out to ViewandEditCVModule.in {
    Property delivery : String = "at-least-once";
    Property ordering : Boolean = false;
    Property backpressure : String = "bounded";
  }
  Attachment ViewandEditCVModule.out to SubmitCVModule.in {
    Property delivery : String = "at-least-once";
    Property ordering : Boolean = false;
    Property backpressure : String = "bounded";
  }
  Attachment AnswerScreeningQuestionsModule.out to ScreeningQuestionValidator.in {
    Property delivery : String = "at-least-once";
    Property ordering : Boolean = true;
    Property backpressure : String = "bounded";
  }
  Attachment ScreeningQuestionValidator.out to RatingGenerator.in {
    Property delivery : String = "at-least-once";
    Property ordering : Boolean = true;
    Property backpressure : String = "bounded";
  }
  Attachment SubmitCVModule.out to ChatGPTValidator.in {
    Property delivery : String = "at-least-once";
    Property ordering : Boolean = true;
    Property backpressure : String = "bounded";
  }
  Attachment ChatGPTValidator.out to RatingGenerator.in {
    Property delivery : String = "at-least-once";
    Property ordering : Boolean = true;
    Property backpressure : String = "bounded";
  }
  Attachment SubmitCVModule.out to CosineSimilarityCalculator.in {
    Property delivery : String = "at-least-once";
    Property ordering : Boolean = true;
    Property backpressure : String = "bounded";
  }
  Attachment CosineSimilarityCalculator.out to CVComparisonModule.in {
    Property delivery : String = "at-least-once";
    Property ordering : Boolean = true;
    Property backpressure : String = "bounded";
  }
  Attachment SubmitCVModule.out to JaccardSimilarityCalculator.in {
    Property delivery : String = "at-least-once";
    Property ordering : Boolean = true;
    Property backpressure : String = "bounded";
  }
  Attachment JaccardSimilarityCalculator.out to CVComparisonModule.in {
    Property delivery : String = "at-least-once";
    Property ordering : Boolean = true;
    Property backpressure : String = "bounded";
  }
  Attachment AnswerScreeningQuestionsModule.out to ChatGPTValidator.in {
    Property delivery : String = "at-least-once";
    Property ordering : Boolean = true;
    Property backpressure : String = "bounded";
  }
  Attachment ChatGPTValidator.out to RatingGenerator.in {
    Property delivery : String = "at-least-once";
    Property ordering : Boolean = true;
    Property backpressure : String = "bounded";
  }
  Property resilience_pattern : String = "Retry";
  Property delivery : String = "at-most-once";
  Property ordering : Boolean = true;
  Property authentication : String = "centralized";
  Property authorization : String = "RBAC";
}