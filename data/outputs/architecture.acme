System ResuFit:PrecisionCVMatchingSystem {
  Property view : String = "runtime";
  Property architectureStyle : String = "Layered (N-Tier)";
  Property source : String = "AI";
  Component UserInterface = new Component {
    Port in;
    Port out;
    Property responsibility : String = "Handle user interactions, including uploading images, recording voice, and conversing with the avatar.";
    Property state : String = "stateless";
    Property scaling : String = "horizontal";
  }
  Component ImageProcessing = new Component {
    Port in;
    Port out;
    Property responsibility : String = "Convert uploaded images to 3D models and generate lifelike digital twin avatars.";
    Property state : String = "stateless";
    Property scaling : String = "horizontal";
  }
  Component VoiceCloning = new Component {
    Port in;
    Port out;
    Property responsibility : String = "Clone the user's voice and make the avatar adapt to the user's voice.";
    Property state : String = "stateless";
    Property scaling : String = "horizontal";
  }
  Component AvatarCustomization = new Component {
    Port in;
    Port out;
    Property responsibility : String = "Allow users to customize their avatar's look and express emotions based on images and conversations.";
    Property state : String = "stateless";
    Property scaling : String = "horizontal";
  }
  Component NaturalLanguageProcessing(NLP) = new Component {
    Port in;
    Port out;
    Property responsibility : String = "Use the GPT-4 model for state-of-the-art natural language processing and respond to user questions.";
    Property state : String = "stateless";
    Property scaling : String = "horizontal";
  }
  Component AuthenticationandAuthorization = new Component {
    Port in;
    Port out;
    Property responsibility : String = "Handle user sign-up, login, profile editing, and logout functionality.";
    Property state : String = "stateless";
    Property scaling : String = "horizontal";
  }
  Component AvatarCreation = new Component {
    Port in;
    Port out;
    Property responsibility : String = "Create avatars based on user requirements and make them adapt to the user.";
    Property state : String = "stateless";
    Property scaling : String = "horizontal";
  }
  Component EmotionExpression = new Component {
    Port in;
    Port out;
    Property responsibility : String = "Make the avatar express emotions based on images and conversations.";
    Property state : String = "stateless";
    Property scaling : String = "horizontal";
  }
  Component SystemAdministration = new Component {
    Port in;
    Port out;
    Property responsibility : String = "Create accounts for administrators and provide access to system data and features.";
    Property state : String = "stateless";
    Property scaling : String = "horizontal";
  }
  Attachment UserInterface.out to ImageProcessing.in {
    Property delivery : String = "at-least-once";
    Property ordering : Boolean = false;
    Property backpressure : String = "bounded";
  }
  Attachment ImageProcessing.out to AvatarCustomization.in {
    Property delivery : String = "at-least-once";
    Property ordering : Boolean = true;
    Property backpressure : String = "bounded";
  }
  Attachment VoiceCloning.out to AvatarCustomization.in {
    Property delivery : String = "at-least-once";
    Property ordering : Boolean = true;
    Property backpressure : String = "bounded";
  }
  Attachment AvatarCustomization.out to EmotionExpression.in {
    Property delivery : String = "at-least-once";
    Property ordering : Boolean = false;
    Property backpressure : String = "bounded";
  }
  Attachment NaturalLanguageProcessing(NLP).out to AvatarCustomization.in {
    Property delivery : String = "at-least-once";
    Property ordering : Boolean = true;
    Property backpressure : String = "bounded";
  }
  Attachment AvatarCreation.out to AvatarCustomization.in {
    Property delivery : String = "at-least-once";
    Property ordering : Boolean = true;
    Property backpressure : String = "bounded";
  }
  Attachment AuthenticationandAuthorization.out to AvatarCreation.in {
    Property delivery : String = "at-least-once";
    Property ordering : Boolean = false;
    Property backpressure : String = "bounded";
  }
  Attachment SystemAdministration.out to AuthenticationandAuthorization.in {
    Property delivery : String = "at-least-once";
    Property ordering : Boolean = false;
    Property backpressure : String = "bounded";
  }
  Property resilience_pattern : String = "Retry";
  Property delivery : String = "at-most-once";
  Property ordering : Boolean = true;
  Property authentication : String = "centralized";
  Property authorization : String = "RBAC";
}